{
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api/.*).*)", "destination": "/index.html" }
  ],
  "redirects": [
    { "source": "/production-studio", "destination": "/main-production-studio", "permanent": true }
  ]
}
